{
  "name": "ci-parity",
  "version": "0.3.0",
  "description": "Statically predict the common 'passes locally, fails in CI' failures before you push: version drift, stale lockfiles, missing env, OS-only shell steps, and npm 12's default-blocked install scripts/git deps/remote deps.",
  "bin": {
    "ci-parity": "bin/cli.js"
  },
  "type": "commonjs",
  "main": "src/index.js",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run.js"
  },
  "keywords": [
    "ci",
    "github-actions",
    "pre-push",
    "git-hook",
    "nvmrc",
    "node-version",
    "lockfile",
    "npm-ci",
    "actionlint",
    "devtools",
    "npm12",
    "install-scripts",
    "supply-chain"
  ],
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernforge/ci-parity.git"
  },
  "bugs": {
    "url": "https://github.com/fernforge/ci-parity/issues"
  },
  "homepage": "https://github.com/fernforge/ci-parity#readme",
  "license": "MIT",
  "author": "fernforge",
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
